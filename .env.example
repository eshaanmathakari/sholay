# Copy this file to `.env` and fill in your key. `.env` is gitignored.
#   cp .env.example .env
#
# Get a key at https://console.anthropic.com/ . Without it, the agent can still
# run `--diagnose` and `--approve-pending`, but live tasks fail at API-call time.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Flow #2 (github_pr) needs NO extra keys. The agent populates Notion by vision (like a
# person), and its oracle machine-verifies the PR reads against the GitHub API (public
# repo, no key). The Notion/invoice leg is human-verified via the approval dialog. A
# Notion integration token is therefore NOT required for this flow.
